# Required
POSTGRES_PASSWORD=change-me-to-something-random

# Domain for TLS (Caddy auto-provisions Let's Encrypt certificates)
DOMAIN=tidemill.xyz

# Stripe connector
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# QuickBooks Online connector (optional — expense data source)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=
QUICKBOOKS_REDIRECT_URI=https://${DOMAIN}/api/connectors/quickbooks/oauth/callback
QUICKBOOKS_ENVIRONMENT=production

# Authentication (Clerk)
AUTH_ENABLED=true
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Observability (OpenTelemetry + Grafana stack)
# Exposed publicly at grafana.${DOMAIN} — rotate the password regularly.
GRAFANA_ADMIN_PASSWORD=change-me-to-something-random
TIDEMILL_OTEL_ENABLED=true
TIDEMILL_ENV=single-server
