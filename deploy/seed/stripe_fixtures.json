{
  "_meta": {
    "template_version": 1,
    "description": "Quick Stripe seed: 3 plans (PAYG + base+metered + flat), 1 customer on Starter. For richer data use stripe_seed.py."
  },
  "fixtures": [
    {
      "name": "starter_product",
      "path": "/v1/products",
      "method": "post",
      "params": {
        "name": "Starter",
        "metadata": {"tier": "starter"}
      }
    },
    {
      "name": "starter_metered",
      "path": "/v1/prices",
      "method": "post",
      "params": {
        "product": "${starter_product:id}",
        "currency": "usd",
        "unit_amount": 2,
        "recurring": {
          "interval": "month",
          "usage_type": "metered"
        },
        "nickname": "Starter — $0.02/query"
      }
    },
    {
      "name": "pro_product",
      "path": "/v1/products",
      "method": "post",
      "params": {
        "name": "Professional",
        "metadata": {"tier": "professional"}
      }
    },
    {
      "name": "pro_base_monthly",
      "path": "/v1/prices",
      "method": "post",
      "params": {
        "product": "${pro_product:id}",
        "unit_amount": 7900,
        "currency": "usd",
        "recurring": {
          "interval": "month"
        },
        "nickname": "Professional — $79/mo base"
      }
    },
    {
      "name": "pro_metered_monthly",
      "path": "/v1/prices",
      "method": "post",
      "params": {
        "product": "${pro_product:id}",
        "currency": "usd",
        "recurring": {
          "interval": "month",
          "usage_type": "metered"
        },
        "billing_scheme": "tiered",
        "tiers_mode": "graduated",
        "tiers": [
          {"up_to": 10000, "unit_amount": 0},
          {"up_to": "inf", "unit_amount": 1}
        ],
        "nickname": "Professional — queries (10k free, then $0.01)"
      }
    },
    {
      "name": "enterprise_product",
      "path": "/v1/products",
      "method": "post",
      "params": {
        "name": "Enterprise",
        "metadata": {"tier": "enterprise"}
      }
    },
    {
      "name": "enterprise_monthly",
      "path": "/v1/prices",
      "method": "post",
      "params": {
        "product": "${enterprise_product:id}",
        "unit_amount": 24900,
        "currency": "usd",
        "recurring": {
          "interval": "month"
        },
        "nickname": "Enterprise — $249/mo"
      }
    },
    {
      "name": "customer",
      "path": "/v1/customers",
      "method": "post",
      "params": {
        "name": "Quick Test Customer",
        "email": "quick-test@example.com",
        "payment_method": "pm_card_visa",
        "invoice_settings": {
          "default_payment_method": "pm_card_visa"
        }
      }
    },
    {
      "name": "subscription",
      "path": "/v1/subscriptions",
      "method": "post",
      "params": {
        "customer": "${customer:id}",
        "items": [
          {"price": "${starter_metered:id}"}
        ]
      }
    }
  ]
}
