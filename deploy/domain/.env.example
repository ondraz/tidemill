# Namecheap API credentials
# Get your API key at: https://ap.www.namecheap.com/settings/tools/apiaccess/
# You must also whitelist your IP there.
NAMECHEAP_API_USER=""
NAMECHEAP_API_KEY=""
NAMECHEAP_CLIENT_IP=""          # Your public IP (must be whitelisted)

# Use sandbox for testing (set to "true" to test without real purchases)
NAMECHEAP_SANDBOX="false"

# WHOIS contact info (applied to all contact roles: Registrant, Tech, Admin, Billing)
CONTACT_FIRST_NAME=""
CONTACT_LAST_NAME=""
CONTACT_ADDRESS=""
CONTACT_CITY=""
CONTACT_STATE=""                # State/Province code (e.g. "CA", "NY")
CONTACT_POSTAL_CODE=""
CONTACT_COUNTRY=""              # Two-letter country code (e.g. "US", "CZ")
CONTACT_PHONE=""                # Format: +1.5555555555
CONTACT_EMAIL=""
