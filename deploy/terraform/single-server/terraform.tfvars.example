# Copy to terraform.tfvars and fill in values.
# Do NOT commit terraform.tfvars — it may contain secrets.

hcloud_token       = ""               # Hetzner API token
tailscale_auth_key = ""               # Tailscale auth key (generate at https://login.tailscale.com/admin/settings/keys)
domain             = "tidemill.dev"
domain_zone        = "tidemill.dev"

# Optional overrides
# server_type         = "cx22"                # cx22, cx32, cax11, etc.
# location            = "fsn1"                # fsn1, nbg1, hel1, ash, hil, sin
# ssh_public_key_path = "~/.ssh/id_ed25519.pub"
