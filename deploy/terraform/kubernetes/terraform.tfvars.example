# Copy to terraform.tfvars and fill in values.
# Do NOT commit terraform.tfvars — it may contain secrets.

hcloud_token = ""                   # Hetzner API token
domain       = "tidemill.dev"
domain_zone  = "tidemill.dev"

# Cluster sizing
# control_plane_type = "cx22"       # 2 vCPU, 4 GB RAM per control plane node (3 nodes)
# worker_type        = "cx32"       # 4 vCPU, 8 GB RAM per worker node
# worker_count       = 2            # Number of worker nodes

# SSH keys
# ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
# ssh_private_key_path = "~/.ssh/id_ed25519"
