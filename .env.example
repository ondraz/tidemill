# Environment variables for subscription analytics engine

# Connector type: stripe | lago | killbill
CONNECTOR=stripe

# Base currency for cross-currency aggregation (ISO 4217).
# All *_base_cents columns are converted to this currency at ingest time.
# Set once before first data ingestion — changing later requires reprocessing.
BASE_CURRENCY=USD

# Currencies the periodic FX sync pulls from Frankfurter (ECB) on top of
# whatever already appears in subscription/invoice/payment. Comma-separated
# ISO 4217 codes. Leave unset to use the built-in default
# (USD,EUR,GBP,CAD,AUD,JPY).
TIDEMILL_FX_CURRENCIES=USD,EUR,GBP,CAD,AUD,JPY

# Database Configuration
# For Stripe: analytics-owned PostgreSQL
# For Lago/Kill Bill: point to the billing engine's PostgreSQL
TIDEMILL_DATABASE_URL=postgresql+asyncpg://tidemill:password@localhost:5432/tidemill

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# QuickBooks Online Configuration (expense data source — optional)
# OAuth credentials from https://developer.intuit.com → My Apps → Keys & OAuth.
# Complete the OAuth flow at /api/connectors/quickbooks/oauth/start to provision
# a per-realm connector_source row containing the refresh token.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=
QUICKBOOKS_REDIRECT_URI=http://localhost:8000/api/connectors/quickbooks/oauth/callback
# environment: sandbox | production
QUICKBOOKS_ENVIRONMENT=sandbox

# QuickBooks Sandbox Seed (optional — only needed if you want
# ./deploy/seed/seed.sh to also populate QBO test data alongside Stripe).
# Obtain by completing the OAuth flow once against a sandbox company, then
# copy refresh_token + realmId from connector_source.config in the DB.
QUICKBOOKS_SANDBOX_REFRESH_TOKEN=
QUICKBOOKS_SANDBOX_REALM_ID=

# Kafka/Redpanda (not needed for Lago/Kill Bill same-database mode)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Authentication
# Set AUTH_ENABLED=false to disable authentication (fully public API)
AUTH_ENABLED=true

# Clerk (required when AUTH_ENABLED=true)
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# JWKS URL for JWT verification (from Clerk dashboard → API Keys → Advanced)
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# ── Terraform (only keys without an app equivalent) ────────────────────
# Stripe/Clerk TF_VAR_ aliases are set in .envrc from the values above.
TF_VAR_hcloud_token=lsa...          # Hetzner Cloud API token (https://console.hetzner.cloud → Security → API Tokens)
TF_VAR_tailscale_auth_key=tskey-auth-...     # Tailscale auth key (https://login.tailscale.com/admin/settings/keys)

# Observability (OpenTelemetry)
# `make dev` starts the OTEL Collector + Grafana stack on localhost; the
# host-run api/worker export traces + metrics here. Grafana: http://localhost:3000
TIDEMILL_OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
TIDEMILL_ENV=local
# Opt into stable HTTP semantic conventions (http.route, seconds).
# Without this, instrumentations still emit the deprecated pre-1.23 names.
OTEL_SEMCONV_STABILITY_OPT_IN=http
# Capture bound parameter values on DB spans (db.statement.parameters).
# Leave off in production — parameters can contain PII.
TIDEMILL_OTEL_CAPTURE_PARAMS=true
